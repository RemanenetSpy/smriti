# KAAL — Environment Variables
# Copy this file to .env and fill in your values

# Groq API (free — hosts DeepSeek R1 at 300+ tok/sec)
# Get your free key at: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Cerebras Inference API (free 1M tokens/day)
# Get your free key at: https://inference.cerebras.ai
CEREBRAS_API_KEY=cbr_your_key_here

# Razorpay (for premium tier billing)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=secret_...
RAZORPAY_PLAN_BUILDER=plan_...
RAZORPAY_PLAN_SCALE=plan_...

# Database Connection
DATABASE_URL=postgresql://user:password@hostname:5432/dbname

# Security
API_SECRET_KEY=change-me-to-a-random-secret

# Cloudflare Turnstile (bot detection on API key generation)
# Sign up free at: https://dash.cloudflare.com → Turnstile
# Use test keys below in dev (always pass). Replace with real keys in production.
NEXT_PUBLIC_CF_TURNSTILE_SITE_KEY=1x00000000000000000000AA
CF_TURNSTILE_SECRET=1x0000000000000000000000000000000AA

# API URL (for Streamlit dashboard)
CHRONOS_API_URL=http://localhost:8000
